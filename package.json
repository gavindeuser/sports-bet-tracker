{
  "name": "sports-bet-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/select-prisma-schema.mjs && prisma generate",
    "dev": "next dev",
    "prebuild": "node scripts/select-prisma-schema.mjs && prisma generate",
    "build": "next build",
    "prestart": "node scripts/select-prisma-schema.mjs && prisma generate",
    "start": "next start",
    "postinstall": "node scripts/select-prisma-schema.mjs && prisma generate",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "node scripts/select-prisma-schema.mjs && prisma generate",
    "prisma:push": "node scripts/select-prisma-schema.mjs && prisma db push",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "import:postgres": "node scripts/import-local-sqlite-to-postgres.mjs",
    "seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.2.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.487.0",
    "next": "^15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.6",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
